# Copy this file to .env.local for local development, or set these as
# Environment Variables in your Vercel project settings for deployment.

# SMTP credentials used by the contact form (app/api/contact/route.ts)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Optional: inbox that should receive contact form submissions (defaults to SMTP_USER)
CONTACT_EMAIL=
